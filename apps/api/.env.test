    # =========================
    # Application
    # =========================
    NODE_ENV=test
    NAME=LinkFlow
    PORT=8081
    API_PREFIX=/api/v1
    BASE_URL=http://localhost

    # =========================
    # Database (test DB)
    # =========================
    POSTGRES_HOST=localhost
    POSTGRES_PORT=5433
    POSTGRES_DB=linkflow_test
    POSTGRES_USER=postgres
    POSTGRES_PASSWORD=postgres

    DATABASE_URL=postgresql://postgres:postgres@localhost:5433/linkflow_test

    # =========================
    # JWT (fake for test)
    # =========================
    JWT_ACCESS_SECRET=test_access_secret
    JWT_REFRESH_SECRET=test_refresh_secret
    JWT_ACCESS_EXPIRES_IN=15m
    JWT_REFRESH_EXPIRES_IN=1d
    JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

    JWT_ACCESS_EXPIRES_MS=900000
    JWT_REFRESH_EXPIRES_MS=86400
    JWT_REFRESH_REMEMBER_EXPIRES_MS=2592000
    # =========================
    # Redis (local)
    # =========================
    REDIS_URL=redis://localhost:6379

    # =========================
    # RabbitMQ (local docker)
    # =========================
    RABBITMQ_URL=amqp://guest:guest@localhost:5672

    # =========================
    # MinIO (local)
    # =========================
    MINIO_ENDPOINT=localhost
    MINIO_PORT=9000
    MINIO_USE_SSL=false

    MINIO_ACCESS_KEY=minioadmin
    MINIO_SECRET_KEY=minioadmin
    MINIO_BUCKET=test-bucket
    MINIO_PUBLIC_URL=http://localhost:9000

    # =========================
    # OAuth
    # =========================
    GOOGLE_CLIENT_ID=test-client-id
    GOOGLE_CLIENT_SECRET=test-client-secret
    GOOGLE_CALLBACK_URL=/auth/google/callback
    GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
    GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
    GOOGLE_USER_INFO_URL=https://openidconnect.googleapis.com/v1/userinfo

    # =========================
    # Mail (mock / dev only)
    # =========================
    SMTP_HOST=localhost
    SMTP_PORT=1025
    SMTP_USER=test
    SMTP_PASSWORD=test
    SMTP_FROM=test@example.com
    SMTP_SECURE=false

    # =========================
    # Frontend
    # =========================
    CLIENT_URL=http://localhost:3000

    # =========================
    # Prisma
    # =========================
    COOKIE_SECRET=test_cookie_secret